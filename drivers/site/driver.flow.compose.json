      "tokens": [
        {
          "name": "error",
          "type": "string",
          "title": {
            "en": "Error message",
            "sv": "Felmeddelande"
          }
        }
      ]
    },
    {
      "id": "eib_connection_restored",
      "highlight": true,
      "title": {
