    {
      "id": "eib_connection_lost",
      "highlight": true,
      "title": {
        "en": "EnergyInBalance could not be reached",
        "sv": "Kunde inte nå EnergyInBalance"
      },
      "hint": {
        "en": "When login or API fails after a successful update. Token: error message.",
